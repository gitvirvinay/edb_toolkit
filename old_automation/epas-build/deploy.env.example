# ==============================================================================
# EPAS BASE INITIALIZATION ENVIRONMENT PARAMETERS
# ==============================================================================

# Target Database Version (e.g., 15, 17, 18)
EPAS_VERSION=17

# Cluster Network Routing
PRIMARY_PORT=5444

# Enterprise Segregation Layout Directory Targets
BINARY_TOP=/u001/binary/as17
DATA_TOP=/u001/data/as17

# Service Unit & Account Configurations
SERVICE_NAME=edb-as-17
SYSTEM_USER=enterprisedb
SYSTEM_GROUP=enterprisedb

# Default Vendor Extraction Source
SRC_BINARY_DIR=/usr/edb/as17

# TDE Configuration (Example using OpenSSL passphrase)
# Ensure to replace 'your-secret-passphrase' with a secure management mechanism
TDE_WRAP_CMD="openssl enc -e -aes-128-cbc -pbkdf2 -pass pass:your-secret-passphrase -out %p"
TDE_UNWRAP_CMD="openssl enc -d -aes-128-cbc -pbkdf2 -pass pass:your-secret-passphrase -in %p"