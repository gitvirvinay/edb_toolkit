# EPAS Version -- must match across all modules
EPAS_VERSION=17
PRIMARY_PORT=5444
BINARY_TOP=/u001/binary/as17
DATA_TOP=/u001/data/as17
SERVICE_NAME=edb-as-17
SYSTEM_USER=enterprisedb
SYSTEM_GROUP=enterprisedb
SRC_BINARY_DIR=/usr/edb/as17
PRIMARY_HOST="192.168.1.11"
STANDBY_HOST="192.168.1.12"
SUBNET_CIDR="192.168.1.0/24"
REP_USER="repuser"

# Replication slot name (Safe fallback for hostname execution under set -u)
CURRENT_HOST="$(hostname -s 2>/dev/null || echo "localhost")"
REP_SLOT_NAME="standby_$(echo "${CURRENT_HOST}" | tr '-' '_')"

# TDE Configuration -- inject passphrase at runtime via secrets manager
TDE_WRAP_CMD="openssl enc -e -aes-128-cbc -pbkdf2 -pass pass:CHANGEME-USE-VAULT-OR-ENV-VAR -out %p"
TDE_UNWRAP_CMD="openssl enc -d -aes-128-cbc -pbkdf2 -pass pass:CHANGEME-USE-VAULT-OR-ENV-VAR -in %p"